<Window x:Class="ClearWord.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Безымянный.clew" Height="650" Width="950"
        WindowStartupLocation="CenterScreen" MinHeight="400" MinWidth="600"
        Background="#F0F0F0" FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Background="#E8E8E8" BorderBrush="#C0C0C0" BorderThickness="0,0,0,1">
            <MenuItem x:Name="FileMenu" Header="_File" Padding="8,4">
                <MenuItem x:Name="NewMenuItem" Header="_New" InputGestureText="Ctrl+N"/>
                <MenuItem x:Name="OpenMenuItem" Header="_Open..." InputGestureText="Ctrl+O"/>
                <Separator/><MenuItem x:Name="SaveMenuItem" Header="_Save" InputGestureText="Ctrl+S"/>
                <MenuItem x:Name="SaveAsMenuItem" Header="Save _As..."/>
                <Separator/><MenuItem x:Name="ExitMenuItem" Header="E_xit"/>
            </MenuItem>
            <MenuItem x:Name="EditMenu" Header="_Edit" Padding="8,4">
                <MenuItem x:Name="UndoMenuItem" Header="_Undo" InputGestureText="Ctrl+Z"/>
                <MenuItem x:Name="RedoMenuItem" Header="_Redo" InputGestureText="Ctrl+Y"/>
                <Separator/><MenuItem x:Name="CutMenuItem" Header="Cu_t" InputGestureText="Ctrl+X"/>
                <MenuItem x:Name="CopyMenuItem" Header="_Copy" InputGestureText="Ctrl+C"/>
                <MenuItem x:Name="PasteMenuItem" Header="_Paste" InputGestureText="Ctrl+V"/>
                <Separator/><MenuItem x:Name="SelectAllMenuItem" Header="Select _All" InputGestureText="Ctrl+A"/>
            </MenuItem>
            <MenuItem x:Name="SettingsMenu" Header="_Settings" Padding="8,4">
                <MenuItem x:Name="SpellCheckMenuItem" Header="Spell Check" IsCheckable="True" IsChecked="True"/>
                <Separator/><MenuItem x:Name="GitHubMenuItem" Header="GitHub"/>
            </MenuItem>
            <MenuItem x:Name="LanguageMenu" Header="_Language" Padding="8,4">
                <MenuItem x:Name="EnglishMenuItem" Header="English" IsCheckable="True" IsChecked="True"/>
                <MenuItem x:Name="RussianMenuItem" Header="Русский" IsCheckable="True"/>
            </MenuItem>
        </Menu>

        <ToolBar Grid.Row="1" Background="White" Padding="6,4" BorderBrush="#C0C0C0" BorderThickness="0,0,0,1">
            <ComboBox x:Name="FontBox" Width="100" Height="26" Margin="4,0"/>
            <ComboBox x:Name="FontSizeBox" Width="60" Height="26" Margin="4,0"/>
            <Separator Margin="4,0"/>
            <Button x:Name="BoldBtn" Content="B" FontWeight="Bold" Width="30" Height="26" Cursor="Hand" Background="Transparent" BorderBrush="Transparent"/>
            <Button x:Name="ItalicBtn" Content="I" FontStyle="Italic" Width="30" Height="26" Cursor="Hand" Background="Transparent" BorderBrush="Transparent"/>
            <Button x:Name="UnderBtn" Width="30" Height="26" Cursor="Hand" Background="Transparent" BorderBrush="Transparent">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Cursor="Hand" Width="30" Height="26">
                            <TextBlock Text="U" TextDecorations="Underline" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Separator Margin="4,0"/>
            <Button x:Name="FontColorBtn" Width="36" Height="26" Cursor="Hand" ToolTip="Цвет текста">
                <TextBlock Text="A" FontSize="14" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>
            <Button x:Name="BgColorBtn" Width="36" Height="26" Cursor="Hand" ToolTip="Цвет холста">
                <TextBlock Text="■" FontSize="16" Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>
        </ToolBar>

        <RichTextBox x:Name="RichBox" Grid.Row="2" Margin="10" Padding="20" FontFamily="Clear" FontSize="14"
                     BorderBrush="#C0C0C0" BorderThickness="1" Background="White"
                     AcceptsTab="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                     SpellCheck.IsEnabled="True" Language="en-US"/>

        <StatusBar Grid.Row="3" Background="#E8E8E8" BorderBrush="#C0C0C0" BorderThickness="0,1,0,0">
            <StatusBarItem Padding="10,0"><TextBlock x:Name="LangStatusText" Text="English"/></StatusBarItem>
            <Separator/>
            <StatusBarItem Padding="10,0"><TextBlock x:Name="WordCountText" Text="Words: 0"/></StatusBarItem>
            <Separator/>
            <StatusBarItem Padding="10,0"><TextBlock x:Name="ModifiedIndicator" Text=""/></StatusBarItem>
        </StatusBar>
    </Grid>
</Window>